 <div class="page-content-wrapper py-4">
      <div class="container-lg">
        <center><h3>Manage Header</h3></center>
                                <a href="/admin" class="btn btn-primary mb-3 mt-3">Back to main</a>
                        <a href="/admin/add-header" class="btn btn-dark mb-3 mt-3">Add Header</a>

        <div class="card">
          <div class="card-body p-3">
            <table class="data-table w-100" id="dataTable">
              <thead>
                <tr>
                  <th>No</th>
                  <th>Image</th>
                  <th>Name</th>
                  <th>Sub Heading</th>
                  <th>Button Link</th>
                  <th>Button Color</th>
                  <th>Button Text</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
               {{#each header}}
                <tr>
                  <td>{{incremented @index}}</td>
                  <td><img src="/images/header-images/{{this._id}}.png" alt="" style="width: 5rem"></td>
                  <td>{{this.Name}}</td>
                  <td>{{this.Sub}}</td>
                  <td>{{this.Link}}</td>
                  <td>{{this.Color}}</td>
                  <td>{{this.Text}}</td>

                  <td>       <div class="dropdown">
                                <button class="btn btn-primary dropdown-toggle" type="button" id="dropdownMenuButton1"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                    Action
                                </button>
                                <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton1">
                                    <li><a class="dropdown-item"
                                            href="/admin/edit-header/{{this._id}}">Edit</a>
                                    </li>
                                    <li><a class="dropdown-item"
                                            href="/admin/delete-header/{{this._id}}" onclick="return confirm('Are You Sure to Cancel This Order ?')">Delete</a>
                                    </li>
                                   
                                </ul>
                            </div></td>
                </tr>
                {{/each}}

             
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>