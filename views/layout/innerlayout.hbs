<style>
  .header-area {
    -webkit-transition-duration: 500ms;
    transition-duration: 500ms;
    background-color: #ffffff;
    width: 100%;
    height: 50px;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    border-bottom: 1px solid #ffffff;
  }

  h2.b {
    visibility: hidden;
  }

  .div2 {
    font: 800 40px system-ui;
    font-weight: 600;
    font-size: 2.5rem;
    color: #0e76a8;
    margin-right: 1rem;
  }
  
</style>
