                  {{#if administator}}
        <div class="user-profile"><img src="img/bg-img/2.jpg" alt=""></div>
                  {{/if}}

        <!-- User Info-->
        <div class="user-info">
          {{#if administator}}
          <h6 class="user-name mb-0">{{administator.Name}}</h6><span>{{administator.Email}}</span>
          {{else}}
          <a href="/signin" class="btn btn-dark w-50 mt-2">Login</a>
          {{/if}}
        </div>
      </div>
      <!-- Sidenav Nav-->
      <ul class="sidenav-nav ps-0">
        <li><a href="/admin"><b><font color="black">Home</font></b></a></li>


        <li><a href="/admin/all-products">
           <b><font color="black">Itmes</font></b> </a></li>

            
